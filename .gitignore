# Generated output (run setup to regenerate)
output/

# MCP config — contains API keys after you fill in placeholders
.mcp.json
.cursor/mcp.json

# Generated agents and skills inside project .claude/ (source lives in .claude/agents/ base + templates/)
# The four base agents (pm-os-onboarding, company-researcher, company-strategy, company-product-signals) are tracked;
# everything else gets regenerated by setup.py.
.claude/agents/feedback-analyzer.md
.claude/agents/weekly-planner.md
.claude/agents/strategy-reviewer.md
.claude/agents/exec-update-generator.md
.claude/agents/retrospective.md
.claude/skills/

# User-specific Claude Code session state (not part of the repo template)
.claude/settings.local.json
.claude/hooks/

# Cursor legacy — session state (for users still running Cursor alongside Claude Code)
.cursor/hooks/
.cursor/rules/

# Local config overrides (optional - keep template in git)
# config/my-config.yaml

# Personal config — contains your name, company, managers, goals; keep local
config/pm-os-config.yaml
